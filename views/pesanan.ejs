<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Pesanan - Warung Bu Neni</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-brand"><i class="fas fa-utensils"></i> Bu Neni</a>
    <button class="nav-toggle" onclick="document.getElementById('navLinks').classList.toggle('open')">
      <i class="fas fa-bars"></i>
    </button>
    <ul class="nav-links" id="navLinks">
      <li><a href="/"><i class="fas fa-home"></i> <span>Home</span></a></li>
      <li><a href="/menu"><i class="fas fa-food"></i> <span>Menu</span></a></li>
      <li><a href="/keranjang"><i class="fas fa-shopping-cart"></i> <span>Keranjang</span></a></li>
      <li><a href="/pesanan" class="active"><i class="fas fa-receipt"></i> <span>Pesanan</span></a></li>
      <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> <span>Logout</span></a></li>
    </ul>
  </div>
</nav>

<main>
  <section class="section" style="padding-top:40px">
    <div class="container">
      <div class="section-title">
        <h2><i class="fas fa-history"></i> Riwayat Pesanan</h2>
        <p>Pesanan yang pernah kamu buat</p>
      </div>
      <% if (pesanan && pesanan.length > 0) { %>
        <% pesanan.forEach(function(p) { %>
          <div class="order-card">
            <div class="order-header">
              <div>
                <span class="order-id">#<%= p.id %></span>
                <span class="order-date" style="margin-left:14px">
                  <i class="far fa-clock"></i> <%= new Date(p.created_at).toLocaleString('id-ID') %>
                </span>
              </div>
              <div style="display:flex;align-items:center;gap:10px">
                <% if (p.payment === 'qris') { %>
                  <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;background:rgba(99,102,241,0.1);color:#4F46E5;font-size:.75rem;font-weight:600">
                    <i class="fas fa-qrcode"></i> QRIS
                  </span>
                <% } else { %>
                  <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;background:rgba(16,185,129,0.1);color:#059669;font-size:.75rem;font-weight:600">
                    <i class="fas fa-money-bill-wave"></i> Cash
                  </span>
                <% } %>
                <span class="status-badge status-<%= p.status %>"><%= p.status %></span>
              </div>
            </div>
            <div class="order-footer">
              <span class="order-total">Total: Rp <%= Number(p.total).toLocaleString('id-ID') %></span>
              <% if (p.catatan) { %>
                <span style="font-size:.82rem;color:var(--gold-400)"><i class="fas fa-sticky-note"></i> <%= p.catatan %></span>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-receipt"></i>
          <h3>Belum ada pesanan</h3>
          <p>Ayo mulai pesan makanan favoritmu</p>
          <a href="/menu" class="btn btn-primary" style="margin-top:16px"><i class="fas fa-food"></i> Pesan Sekarang</a>
        </div>
      <% } %>
    </div>
  </section>
</main>

<footer class="footer"><p>&copy; 2024 <strong>Warung Makan Bu Neni</strong> &mdash; Cita Rasa Nusantara</p></footer>
<script src="/js/effects.js"></script>
</body>
</html>